{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soma Scratchpad",
  "version": "0.4.2",
  "identifier": "com.soma.scratchpad",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Soma Scratchpad",
        "width": 360,
        "height": 640,
        "minWidth": 240,
        "minHeight": 180,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "dragDropEnabled": true
      },
      {
        "label": "minimized-tab",
        "title": "Soma Scratchpad",
        "width": 48,
        "height": 48,
        "minWidth": 48,
        "minHeight": 48,
        "maxWidth": 48,
        "maxHeight": 48,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://asset.localhost data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ws:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$EXE/data/**"]
        }
      }
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Soma Scratchpad"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFMkE5M0E5NzY0QTE5REEKUldUYUdVcDJxWk1xbmtiK0l3c1pFRVloRkhrdlo3NC9pcWJNUUxud2pxVzZmT01SVjVidHl2eXYK",
      "endpoints": [
        "https://github.com/SiChuchen/Scratchpad/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
